# -------------------------------
# STC Control Line Calculation Function
# -------------------------------
def calculate_x(t, mu, Q, R, sigma, z_alpha):
    """
    Calculate the control line:
      x = -((mu - Q) * (R - t) / R) - z_alpha * sigma * sqrt((R - t)/R)
    """
    return -((mu - Q) * (R - t) / R) - z_alpha * sigma * np.sqrt((R - t) / R)

# -------------------------------
# STC Control Line Tool
# -------------------------------
def stc_control_lines(t_vals, mu, Q, R, sigma, z_vals):
    lines = {}
    for z in z_vals:
        lines[z] = [calculate_x(t, mu, Q, R, sigma, z) for t in t_vals]
    return lines

# -------------------------------
# Plot STC Chart Function (with annotation)
# -------------------------------
def plot_stc_chart(record, target, R, mu, sigma, title="STC Chart", annotation=""):
    """
    Plot the STC chart:
      - Planned production: target * (t/R)
      - Production difference: actual - planned
      - Multiple control lines are overlayed
      - An optional annotation is added on the top-left corner
    """
    times = [t for (t, prod) in record]
    actual = [prod for (t, prod) in record]
    planned = [target * (t / R) for t in times]
    diff = [a - p for a, p in zip(actual, planned)]

    t_vals = np.linspace(0, R, 100)
    z_vals = [-1.675, -0.674, 0, 0.674, 1.675]
    control = stc_control_lines(t_vals, mu, target, R, sigma, z_vals)

    plt.figure(figsize=(10, 6))
    for z in z_vals:
        plt.plot(t_vals, control[z], label=f"Control (z={z})")
    plt.plot(times, diff, 'k--', lw=2, label="Production Difference")
    plt.xlabel("Time (hours)")
    plt.ylabel("Difference (units)")
    plt.title(title)
    plt.legend()
    plt.grid(True)

    # Add annotation text if provided
    if annotation:
        plt.gca().text(0.02, 0.98, annotation, transform=plt.gca().transAxes,
                       fontsize=10, verticalalignment='top',
                       bbox=dict(boxstyle="round", facecolor="wheat", alpha=0.5))

    plt.show()

# -------------------------------
# Discrete Simulation: Add Manpower Strategy
# -------------------------------
def production_process_manpower_discrete(env, R, quota, initial_workers, T_add, additional_workers, prod_mean, prod_variance, time_intervals, record, result, verbose=False):
    dt = R / time_intervals
    mean_dt = prod_mean * dt
    std_dt = np.sqrt(prod_variance * dt)
    cumulative_production = 0.0
    finish_time = None
    worker_count = initial_workers
    record.append((env.now, cumulative_production))
    for i in range(time_intervals):
        yield env.timeout(dt)
        t = env.now
        # At T_add, add additional workers (only once)
        if t >= T_add and worker_count == initial_workers:
            worker_count += additional_workers
            if verbose:
                print(f"At time {t:.2f} hrs: Added {additional_workers} workers; total now {worker_count}")
        if cumulative_production < quota:
            raw_samples = np.random.normal(mean_dt, std_dt, size=worker_count)
            samples = np.maximum(raw_samples, 0)
            production_dt = np.sum(samples)
            # If production in this interval exceeds quota, interpolate to get the exact finish time
            if cumulative_production + production_dt >= quota:
                fraction = (quota - cumulative_production) / production_dt
                finish_time = t - dt + fraction * dt
                production_dt = quota - cumulative_production
                cumulative_production += production_dt
                record.append((finish_time, cumulative_production))
                if verbose:
                    print(f"[Completed] at {finish_time:.2f} hrs, cumulative production: {cumulative_production:.2f}")
                break
            else:
                cumulative_production += production_dt
                record.append((t, cumulative_production))
    result["finish_time"] = finish_time
    result["cumulative_production"] = cumulative_production

# -------------------------------
# Discrete Simulation: Overtime Strategy
# -------------------------------
def production_process_overtime_discrete(env, R, quota, n_worker, prod_mean, prod_variance, time_intervals, record, result, verbose=False):
    dt = R / time_intervals
    mean_dt = prod_mean * dt
    std_dt = np.sqrt(prod_variance * dt)
    cumulative_production = 0.0
    finish_time = None
    record.append((env.now, cumulative_production))
    for i in range(time_intervals):
        yield env.timeout(dt)
        t = env.now
        if cumulative_production < quota:
            raw_samples = np.random.normal(mean_dt, std_dt, size=n_worker)
            samples = np.maximum(raw_samples, 0)
            production_dt = np.sum(samples)
            if cumulative_production + production_dt >= quota:
                fraction = (quota - cumulative_production) / production_dt
                finish_time = t - dt + fraction * dt
                production_dt = quota - cumulative_production
                cumulative_production += production_dt
                record.append((finish_time, cumulative_production))
                if verbose:
                    print(f"[Completed] at {finish_time:.2f} hrs, cumulative production: {cumulative_production:.2f}")
                break
            else:
                cumulative_production += production_dt
                record.append((t, cumulative_production))
    result["finish_time"] = finish_time
    result["cumulative_production"] = cumulative_production

# -------------------------------
# Simulation Execution Functions
# -------------------------------
def run_simulation_manpower_discrete(R, quota, initial_workers, T_add, additional_workers, prod_mean, prod_variance, time_intervals, verbose=False):
    env = simpy.Environment()
    record = []
    result = {}
    env.process(production_process_manpower_discrete(env, R, quota, initial_workers, T_add, additional_workers, prod_mean, prod_variance, time_intervals, record, result, verbose))
    env.run()
    finish_time = result.get("finish_time", None)
    cumulative_production = result.get("cumulative_production", 0)
    return record, finish_time, cumulative_production

def run_simulation_overtime_discrete(R, quota, n_worker, prod_mean, prod_variance, time_intervals, verbose=False):
    env = simpy.Environment()
    record = []
    result = {}
    env.process(production_process_overtime_discrete(env, R, quota, n_worker, prod_mean, prod_variance, time_intervals, record, result, verbose))
    env.run()
    finish_time = result.get("finish_time", None)
    cumulative_production = result.get("cumulative_production", 0)
    return record, finish_time, cumulative_production

# -------------------------------
# Helper Function: Production at Time R
# -------------------------------
def get_production_at_R(record, R):
    """
    Retrieve the last production data point within time <= R; return 0 if none.
    """
    prod_at_R = 0.0
    for t, prod in record:
        if t <= R:
            prod_at_R = prod
        else:
            break
    return prod_at_R

# -------------------------------
# Estimate Completion Time (if not achieved within simulation)
# -------------------------------
def estimate_finish_time(record, R, quota):
    """
    Estimate total time to reach quota, assuming constant production rate based on production within R hours.
    """
    production_at_R = get_production_at_R(record, R)
    if production_at_R <= 0:
        return None
    extra_time = R * (quota - production_at_R) / production_at_R
    return R + extra_time

# -------------------------------
# Updated Manpower Strategy Cost Calculation Function
# -------------------------------
def calculate_costs_manpower(T_finish, T_add, additional_workers, n_worker, wage, R):
    """
    Manpower strategy cost:
      - Initial workers cost: if T_finish <= R, cost = n_worker * wage * T_finish;
        if T_finish > R, then first R hours at normal wage, remaining at 1.5 * wage.
      - Additional workers cost: only if T_finish > T_add, working period from T_add to T_finish is considered:
          Normal hours: from T_add to min(T_finish, R)
          Overtime hours: from R to T_finish (if applicable) at 1.5 * wage.
    """
    if T_finish <= R:
        cost_initial = n_worker * wage * T_finish
    else:
        cost_initial = n_worker * (wage * R + wage * 1.5 * (T_finish - R))

    if T_finish <= T_add:
        cost_additional = 0
    else:
        normal_hours = min(T_finish, R) - T_add
        overtime_hours = max(0, T_finish - R)
        cost_additional = additional_workers * (wage * normal_hours + wage * 1.5 * overtime_hours)

    return cost_initial + cost_additional

# -------------------------------
# Overtime Strategy Cost Calculation Function
# -------------------------------
def calculate_costs_overtime(T_finish, R, n_worker, wage):
    """
    Overtime strategy cost:
      - If T_finish <= R: cost = n_worker * wage * T_finish
      - If T_finish > R: cost = n_worker * wage * R + n_worker * wage * 1.5 * (T_finish - R)
    """
    if T_finish <= R:
        return n_worker * wage * T_finish
    else:
        return n_worker * wage * R + n_worker * wage * 1.5 * (T_finish - R)

# -------------------------------
# Multiple Simulation Statistics: Y_Completion and Y_Production_Ratio
# -------------------------------
def simulate_target_probability_discrete(simulation_func, R, quota, *args, time_intervals=100, iterations=1000, verbose=False):
    success_count = 0
    production_ratios = []
    last_record = None
    for i in range(iterations):
        np.random.seed(123 + i)
        record, finish_time, cumulative_production = simulation_func(R, quota, *args, time_intervals, verbose)
        if finish_time is not None and finish_time <= R:
            success_count += 1
        production_ratios.append(cumulative_production / quota * 100)
        last_record = record
    return success_count / iterations, np.mean(production_ratios), last_record

